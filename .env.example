# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_money_scoreboard?schema=public"

# Key vault (required — 32-byte master key as 64-char hex or base64; use KMS in production)
KEY_VAULT_SECRET=

# Anthropic (optional platform fallback for local dev — readiness phrasing only)
ANTHROPIC_API_KEY="sk-ant-..."

# Optional platform fallbacks for local dev — BYOK keys come from each user's vault
PERPLEXITY_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
SERPAPI_KEY=""
GOOGLE_KG_API_KEY=""

# Supabase Auth
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Storage
STORAGE_PATH="./storage"

# Rate limiting (readiness scans)
SCAN_RATE_LIMIT_WINDOW_MS=3600000
SCAN_RATE_LIMIT_MAX=10

# Queue (Deep Scan requires Redis in production)
REDIS_URL=""
VISIBILITY_CONCURRENCY=2
DEEP_SCAN_MAX_COST_USD=2
